---
interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title = "ShioriCode — The best way to code with agents",
  description = "Run Codex, Claude, Gemini, Cursor, Kimi, and Shiori side by side in one checkpointed desktop workspace.",
  canonicalPath = "/",
} = Astro.props;
const canonical = new URL(canonicalPath, "https://shiori.codes");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f7f6" />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://shiori.codes/shiori-code.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://shiori.codes/shiori-code.png" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip" href="#main-content">Skip to main content</a>
    <div class="page-shell">
      <nav class="nav" aria-label="Main navigation">
        <a class="brand" href="/">
          <img src="/logo.svg" alt="" width="18" height="18" />
          <span><strong>Shiori</strong> <em>Code</em></span>
          <small>Beta</small>
        </a>
        <div class="nav-links">
          <a href="https://www.shiori.ai/docs/shioricode">Docs</a>
          <a href="https://www.shiori.ai/pricing">Pricing</a>
          <a href="https://www.shiori.ai/chat">Open app <span aria-hidden="true">↗</span></a>
        </div>
      </nav>
      <div class="rule"></div>
      <main id="main-content"><slot /></main>
      <footer class="footer">
        <a class="footer-brand" href="/"><img src="/logo.svg" alt="" width="16" height="16" /> ShioriCode</a>
        <span>© {new Date().getFullYear()} Shiori · Beta</span>
        <div>
          <a href="https://www.shiori.ai/privacy">Privacy</a>
          <a href="https://www.shiori.ai/terms">Terms</a>
          <a href="https://www.shiori.ai/docs/shioricode">Docs</a>
          <a href="https://github.com/shiorihq/ShioriCode/releases">Changelog</a>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f7f7f6;
    --surface: #fff;
    --fg: #101116;
    --muted: #686a70;
    --dim: #97999e;
    --line: rgba(16, 17, 22, 0.11);
    --accent: #70aee8;
  }
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; background: var(--bg); }
  body { margin: 0; min-width: 320px; background: var(--bg); color: var(--fg); font-family: "DM Sans", system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }
  .page-shell { width: min(100%, 1120px); margin: 0 auto; padding: 0 40px; }
  .skip { position: fixed; left: 16px; top: -60px; z-index: 20; padding: 10px 14px; background: var(--fg); color: white; border-radius: 8px; }
  .skip:focus { top: 16px; }
  .nav { height: 62px; display: flex; align-items: center; justify-content: space-between; }
  .brand { display: inline-flex; align-items: center; gap: 9px; font-size: 14px; }
  .brand img { width: 18px; height: 18px; }
  .brand strong { font-weight: 600; }
  .brand em { font-family: "Instrument Serif", serif; font-size: 15px; color: #4f5157; }
  .brand small { margin-left: 7px; border: 1px solid var(--line); border-radius: 999px; padding: 2px 7px 1px; color: var(--dim); font: 9px/1.2 "DM Mono", monospace; text-transform: uppercase; letter-spacing: .13em; }
  .nav-links { display: flex; align-items: center; gap: 30px; color: #55575d; font-size: 13px; }
  .nav-links a, .footer a { transition: color .2s ease; }
  .nav-links a:hover, .footer a:hover { color: var(--accent); }
  .rule { height: 1px; background: var(--line); }
  .footer { min-height: 100px; border-top: 1px solid var(--line); display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 24px; color: var(--dim); font: 11px "DM Mono", monospace; }
  .footer-brand { justify-self: start; display: inline-flex; align-items: center; gap: 8px; color: var(--fg); font-family: "DM Sans", sans-serif; }
  .footer > div { justify-self: end; display: flex; gap: 18px; }
  @media (max-width: 720px) {
    .page-shell { padding: 0 22px; }
    .nav-links { gap: 18px; }
    .nav-links a:nth-child(-n+2) { display: none; }
    .footer { padding: 28px 0; grid-template-columns: 1fr; text-align: left; }
    .footer > *, .footer > div { justify-self: start; }
  }
  @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; } }
</style>
